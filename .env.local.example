# ============================================================
# Pegasus AI — environment configuration
# Copy this file to .env.local and fill in at least ONE AI key.
# Priority order: Anthropic → Gemini → Groq → Ollama → demo mode
# ============================================================

# ── Option 1: Anthropic (Claude) ──────────────────────────
# Best quality. Get a key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8   # optional, this is the default

# ── Option 2: Google Gemini ───────────────────────────────
# Great quality. Get a key at https://aistudio.google.com
# GOOGLE_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.5-flash   # optional, this is the default
# Note: gemini-2.0-flash no longer has free-tier quota (429 limit:0).
# Other models: gemini-2.5-pro, gemini-2.5-flash-lite (highest free RPD)

# ── Option 3: Groq (free, open-source models) ─────────────
# Very fast. Free tier. Get a key at https://console.groq.com
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-70b-versatile   # optional, this is the default
# Other Groq models: llama-3.1-8b-instant, mixtral-8x7b-32768

# ── Option 4: Ollama (fully local, no API key) ────────────
# Install: brew install ollama && ollama pull llama3.1
# Then run: ollama serve
# OLLAMA_BASE_URL=http://localhost:11434/v1   # optional, this is the default
# OLLAMA_MODEL=llama3.1                       # optional, this is the default
# Good models: qwen2.5-coder:7b, mistral, deepseek-r1:8b

# ── GitHub (optional, for push-to-repo feature) ───────────
# Needed only for the "Ship" feature. Needs repo scope.
# GITHUB_TOKEN=ghp_...

# ============================================================
# Authentication (Auth.js / NextAuth)
# Email + password accounts work out of the box (users stored in the DB or
# .data/users.json). AUTH_SECRET is REQUIRED in production — generate one
# below. OAuth providers are optional extras.
# ============================================================
# Generate a secret with: npx auth secret   (or: openssl rand -base64 32)
# AUTH_SECRET=...

# Google OAuth — console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: <your-site>/api/auth/callback/google
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...

# GitHub OAuth — github.com/settings/developers → New OAuth App
# Authorization callback URL: <your-site>/api/auth/callback/github
# AUTH_GITHUB_ID=...
# AUTH_GITHUB_SECRET=...

# Public site URL — used for OAuth callbacks and OG image URLs in production.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ============================================================
# Resend (transactional email) — optional
# Without it, contact form and welcome emails are silently skipped.
# Get a key at https://resend.com — verify your domain for custom from address.
# ============================================================
# RESEND_API_KEY=re_...
# RESEND_FROM=Pegasus Lab <hello@yourdomain.com>
# RESEND_INBOX=you@yourdomain.com   # where contact form submissions land

# ============================================================
# Database (Neon Postgres) — optional
# Without it, projects are stored in a local .data/projects.json file.
# Create a free DB at neon.tech and paste the pooled connection string.
# ============================================================
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
